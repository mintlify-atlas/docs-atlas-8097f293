{
  "$schema": "https://mintlify.com/docs.json",
  "name": "Namida",
  "theme": "palm",
  "colors": {
    "primary": "#94cb04",
    "light": "#545454",
    "dark": "#94cb04"
  },
  "favicon": "/logo.png",
  "logo": {
    "light": "/logo.png",
    "dark": "/logo.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/namidaco/namida"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/namidaco/namida",
      "discord": "https://discord.gg/WeY7DTVChT"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": [
              "introduction",
              "installation",
              "quickstart"
            ]
          },
          {
            "group": "Core Features",
            "pages": [
              "features/library",
              "features/youtube",
              "features/video-playback",
              "features/playlists",
              "features/queue",
              "features/history"
            ]
          },
          {
            "group": "Audio & Playback",
            "pages": [
              "playback/audio-effects",
              "playback/lyrics",
              "playback/sleep-timer",
              "playback/crossfade"
            ]
          },
          {
            "group": "Customization",
            "pages": [
              "customization/themes",
              "customization/ui-settings",
              "customization/gestures",
              "customization/miniplayer"
            ]
          },
          {
            "group": "Advanced",
            "pages": [
              "advanced/indexer",
              "advanced/tag-editor",
              "advanced/backup-restore",
              "advanced/import-history"
            ]
          },
          {
            "group": "Platform Support",
            "pages": [
              "platforms/android",
              "platforms/windows",
              "platforms/linux"
            ]
          }
        ]
      },
      {
        "tab": "Community",
        "groups": [
          {
            "group": "Resources",
            "pages": [
              "community/faq",
              "community/troubleshooting",
              "community/contributing",
              "community/translations"
            ]
          }
        ]
      }
    ]
  }
}
